# PostgreSQL Database Connection
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/rwanda_connect

# Payload CMS Secret (generate a strong random string)
PAYLOAD_SECRET=your-super-secret-key-here

# Comma-separated allowed origins for CORS/CSRF
CORS_ORIGINS=http://localhost:3000

# Optional: force email verification on/off (defaults to on in production, off in local dev)
PAYLOAD_ENABLE_EMAIL_VERIFICATION=false

# SendGrid Email Configuration
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Rwanda Connect
